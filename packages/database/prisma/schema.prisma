generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  COMPANION
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
}

enum GameCode {
  DELTA_FORCE
  LEAGUE_OF_LEGENDS
  VALORANT
  COUNTER_STRIKE_2
  PUBG
  PUBG_MOBILE
  APEX_LEGENDS
  NARAKA_BLADEPOINT
  HONOR_OF_KINGS
  PEACEKEEPER_ELITE
  DOTA_2
  OVERWATCH_2
  RAINBOW_SIX_SIEGE
  ROCKET_LEAGUE
  EA_SPORTS_FC
  STREET_FIGHTER_6
  CALL_OF_DUTY
  WILD_RIFT
  MOBILE_LEGENDS
  MINECRAFT
  GENSHIN_IMPACT
}

enum DeltaForceRank {
  UNRANKED
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
  ASCENDANT
  IMMORTAL
  TOP
}

enum CompanionProfileStatus {
  PENDING_REVIEW
  LISTED
  UNLISTED
  BANNED
}

enum OnlineStatus {
  ONLINE
  BUSY
  OFFLINE
}

enum VoicePreference {
  REQUIRED
  OPTIONAL
  TEXT_ONLY
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  ASSIGNED
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REFUND_REQUESTED
  REFUNDED
  DISPUTED
}

enum OrderAssignmentType {
  DIRECT_COMPANION
  PLATFORM_MATCH
}

enum OrderSourcePlatform {
  WEB
  DISCORD
  KOOK
}

enum OrderDraftStatus {
  OPEN
  TRIALING
  SELECTED
  CUSTOMER_CONFIRMED
  CONVERTED
  CANCELLED
}

enum OrderDraftCandidateStatus {
  RECOMMENDED
  TRIALING
  LIKED
  REJECTED
  SELECTED
}

enum OrderDraftActorType {
  CUSTOMER
  ADMIN
  COMPANION
  BOT
}

enum OrderDraftEventType {
  DRAFT_CREATED
  CUSTOMER_REQUESTED_ORDER
  COMPANION_APPLIED
  COMPANION_RECOMMENDED
  COMPANION_TRIAL_STARTED
  CUSTOMER_SELECTED_COMPANION
  CUSTOMER_CHANGED_COMPANION
  CUSTOMER_CONFIRMED
  DRAFT_CONVERTED_TO_ORDER
  DRAFT_CANCELLED
  NOTE_ADDED
}

enum WalletTransactionType {
  RECHARGE_APPROVED
  ORDER_PAYMENT
  ORDER_REFUND
  ORDER_SETTLEMENT
  WITHDRAWAL_FREEZE
  WITHDRAWAL_COMPLETED
  WITHDRAWAL_REJECTED
  ADMIN_ADJUSTMENT
  PROMOTION_BONUS
  REFERRAL_REWARD
}

enum ReferralRewardStatus {
  PENDING
  REWARDED
  CANCELLED
}

enum ReferralSourceType {
  CUSTOMER
  COMPANION
  ADMIN
}

enum TransactionDirection {
  CREDIT
  DEBIT
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum ComplaintStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  REJECTED
}

enum BotEventType {
  ORDER_NOTIFICATION_SENT
  ORDER_ACCEPT_CLICKED
  RECHARGE_NOTIFICATION_SENT
  WITHDRAWAL_NOTIFICATION_SENT
  COMPLAINT_NOTIFICATION_SENT
  ADMIN_ALERT_SENT
}

enum BotPlatform {
  DISCORD
  KOOK
}

enum BotEventStatus {
  PENDING
  SENT
  FAILED
}

model User {
  id                         String              @id @default(cuid())
  email                      String              @unique
  passwordHash               String
  role                       UserRole
  status                     UserStatus          @default(ACTIVE)
  displayName                String
  displayNameKey             String
  referralCode               String?             @unique
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt

  wallet                     Wallet?
  companionProfile           CompanionProfile?
  customerOrders             Order[]             @relation("OrderCustomer")
  companionOrders            Order[]             @relation("OrderCompanion")
  assignedOrders             Order[]             @relation("OrderAssigner")
  customerOrderDrafts         OrderDraft[]        @relation("OrderDraftCustomer")
  serviceOrderDrafts          OrderDraft[]        @relation("OrderDraftServiceAdmin")
  selectedOrderDrafts         OrderDraft[]        @relation("OrderDraftSelectedCompanion")
  convertedOrderDrafts        OrderDraft[]        @relation("OrderDraftConverter")
  draftCandidates             OrderDraftCandidate[] @relation("OrderDraftCandidateCompanion")
  draftCandidateRecommends    OrderDraftCandidate[] @relation("OrderDraftCandidateRecommender")
  orderDraftEvents            OrderDraftEvent[]   @relation("OrderDraftEventActor")
  orderStatusLogs            OrderStatusLog[]    @relation("OrderStatusActor")
  walletTransactions         WalletTransaction[] @relation("WalletTransactionUser")
  operatedWalletTransactions WalletTransaction[] @relation("WalletTransactionOperator")
  referralsGiven             UserReferral[]      @relation("ReferralReferrer")
  referralReceived           UserReferral?       @relation("ReferralReferredUser")
  rechargeRequests           RechargeRequest[]   @relation("RechargeCustomer")
  rechargeReviews            RechargeRequest[]   @relation("RechargeReviewer")
  withdrawalRequests         WithdrawalRequest[] @relation("WithdrawalCompanion")
  withdrawalReviews          WithdrawalRequest[] @relation("WithdrawalReviewer")
  complaintsFiled            Complaint[]         @relation("ComplaintReporter")
  complaintsResolved         Complaint[]         @relation("ComplaintResolver")
  adminLogs                  AdminLog[]          @relation("AdminLogActor")
  targetAdminLogs            AdminLog[]          @relation("AdminLogTarget")
  updatedPlatformSettings    PlatformSetting[]   @relation("PlatformSettingUpdater")
  botEvents                  BotEvent[]          @relation("BotEventActor")
  externalAccounts           UserExternalAccount[]
  supportConversations       AiSupportConversation[]

  @@unique([role, displayNameKey])
  @@map("users")
}

model EmailVerificationCode {
  id         String    @id @default(cuid())
  email      String
  purpose    String
  codeHash   String
  attempts   Int       @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email, purpose])
  @@index([expiresAt])
  @@map("email_verification_codes")
}

model UserExternalAccount {
  id             String      @id @default(cuid())
  userId         String
  platform       BotPlatform
  externalUserId String
  displayName    String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user           User        @relation(fields: [userId], references: [id])

  @@unique([platform, externalUserId])
  @@unique([userId, platform])
  @@index([userId])
  @@map("user_external_accounts")
}

model CompanionProfile {
  id              String                 @id @default(cuid())
  userId          String                 @unique
  nickname        String
  avatarUrl       String?
  gender          String?
  game            GameCode               @default(DELTA_FORCE)
  deltaForceRank  DeltaForceRank         @default(UNRANKED)
  skillModes      String[]
  pricePerHour    Decimal                @db.Decimal(12, 2)
  commissionRate  Decimal                @default(0.2) @db.Decimal(5, 4)
  onlineStatus    OnlineStatus           @default(OFFLINE)
  bio             String?
  voicePreference VoicePreference        @default(OPTIONAL)
  status          CompanionProfileStatus @default(PENDING_REVIEW)
  payoutMethod    String?
  payoutAccountName String?
  payoutAccountNo String?
  payoutQrCodeUrl String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  user            User                   @relation(fields: [userId], references: [id])

  @@map("companion_profiles")
}

model Wallet {
  id               String              @id @default(cuid())
  userId           String              @unique
  availableBalance Decimal             @default(0) @db.Decimal(12, 2)
  frozenBalance    Decimal             @default(0) @db.Decimal(12, 2)
  availableIncome  Decimal             @default(0) @db.Decimal(12, 2)
  pendingIncome    Decimal             @default(0) @db.Decimal(12, 2)
  frozenIncome     Decimal             @default(0) @db.Decimal(12, 2)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  user             User                @relation(fields: [userId], references: [id])
  transactions     WalletTransaction[]

  @@map("wallets")
}

model Order {
  id                String           @id @default(cuid())
  orderNo           String           @unique
  customerId        String
  companionId       String?
  assignedById      String?
  assignmentType    OrderAssignmentType @default(DIRECT_COMPANION)
  game              GameCode         @default(DELTA_FORCE)
  mode              String
  hours             Decimal          @db.Decimal(6, 2)
  unitPrice         Decimal          @db.Decimal(12, 2)
  totalAmount       Decimal          @db.Decimal(12, 2)
  platformFee       Decimal          @default(0) @db.Decimal(12, 2)
  companionIncome   Decimal          @default(0) @db.Decimal(12, 2)
  status            OrderStatus      @default(PENDING_PAYMENT)
  notes             String?
  voiceTrialRequested Boolean         @default(false)
  voiceRoomId       String?
  discordMessageId  String?
  sourcePlatform    OrderSourcePlatform @default(WEB)
  sourceDraftId     String?          @unique
  sourceChannelId   String?
  sourceMessageId   String?
  acceptedAt        DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  customer          User             @relation("OrderCustomer", fields: [customerId], references: [id])
  companion         User?            @relation("OrderCompanion", fields: [companionId], references: [id])
  assignedBy        User?            @relation("OrderAssigner", fields: [assignedById], references: [id])
  sourceDraft       OrderDraft?      @relation("OrderSourceDraft", fields: [sourceDraftId], references: [id])
  statusLogs        OrderStatusLog[]
  complaints        Complaint[]
  referralRewards   UserReferral[]   @relation("ReferralFirstOrder")

  @@index([status])
  @@index([customerId])
  @@index([companionId])
  @@index([sourceDraftId])
  @@map("orders")
}

model UserReferral {
  id             String               @id @default(cuid())
  referrerId     String
  referredUserId String               @unique
  sourceType     ReferralSourceType
  rewardStatus   ReferralRewardStatus @default(PENDING)
  firstOrderId   String?
  rewardedAt     DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  referrer        User                 @relation("ReferralReferrer", fields: [referrerId], references: [id])
  referredUser    User                 @relation("ReferralReferredUser", fields: [referredUserId], references: [id])
  firstOrder      Order?               @relation("ReferralFirstOrder", fields: [firstOrderId], references: [id])

  @@index([referrerId])
  @@index([rewardStatus])
  @@map("user_referrals")
}

model OrderDraft {
  id                     String              @id @default(cuid())
  draftNo                String              @unique
  customerId             String?
  serviceAdminId         String
  selectedCompanionId    String?
  convertedById          String?
  sourcePlatform         OrderSourcePlatform
  customerPlatformUserId String?
  customerDisplayName    String?
  sourceGuildId          String?
  sourceChannelId        String?
  sourceMessageId        String?
  voiceRoomId            String?
  game                   GameCode            @default(DELTA_FORCE)
  mode                   String
  hours                  Decimal?            @db.Decimal(6, 2)
  budgetAmount           Decimal?            @db.Decimal(12, 2)
  status                 OrderDraftStatus    @default(OPEN)
  note                   String?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  customer               User?               @relation("OrderDraftCustomer", fields: [customerId], references: [id])
  serviceAdmin           User                @relation("OrderDraftServiceAdmin", fields: [serviceAdminId], references: [id])
  selectedCompanion      User?               @relation("OrderDraftSelectedCompanion", fields: [selectedCompanionId], references: [id])
  convertedBy            User?               @relation("OrderDraftConverter", fields: [convertedById], references: [id])
  convertedOrder         Order?              @relation("OrderSourceDraft")
  candidates             OrderDraftCandidate[]
  events                 OrderDraftEvent[]

  @@index([status])
  @@index([customerId])
  @@index([serviceAdminId])
  @@index([selectedCompanionId])
  @@map("order_drafts")
}

model OrderDraftCandidate {
  id              String                    @id @default(cuid())
  draftId         String
  companionId     String
  recommendedById String?
  status          OrderDraftCandidateStatus @default(RECOMMENDED)
  note            String?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  draft           OrderDraft                @relation(fields: [draftId], references: [id])
  companion       User                      @relation("OrderDraftCandidateCompanion", fields: [companionId], references: [id])
  recommendedBy   User?                     @relation("OrderDraftCandidateRecommender", fields: [recommendedById], references: [id])

  @@unique([draftId, companionId])
  @@index([companionId])
  @@map("order_draft_candidates")
}

model OrderDraftEvent {
  id             String              @id @default(cuid())
  draftId        String
  actorType      OrderDraftActorType
  actorUserId    String?
  platform       OrderSourcePlatform
  platformUserId String?
  eventType      OrderDraftEventType
  content        String?
  metadata       Json?
  createdAt      DateTime            @default(now())

  draft          OrderDraft          @relation(fields: [draftId], references: [id])
  actor          User?               @relation("OrderDraftEventActor", fields: [actorUserId], references: [id])

  @@index([draftId])
  @@index([eventType])
  @@map("order_draft_events")
}

model OrderStatusLog {
  id         String      @id @default(cuid())
  orderId    String
  fromStatus OrderStatus?
  toStatus   OrderStatus
  actorId    String?
  reason     String?
  createdAt  DateTime    @default(now())

  order      Order       @relation(fields: [orderId], references: [id])
  actor      User?       @relation("OrderStatusActor", fields: [actorId], references: [id])

  @@index([orderId])
  @@map("order_status_logs")
}

model WalletTransaction {
  id             String                @id @default(cuid())
  walletId       String
  userId         String
  operatorId     String?
  type           WalletTransactionType
  direction      TransactionDirection
  amount         Decimal               @db.Decimal(12, 2)
  balanceAfter   Decimal               @db.Decimal(12, 2)
  referenceType  String?
  referenceId    String?
  note           String?
  createdAt      DateTime              @default(now())

  wallet         Wallet                @relation(fields: [walletId], references: [id])
  user           User                  @relation("WalletTransactionUser", fields: [userId], references: [id])
  operator       User?                 @relation("WalletTransactionOperator", fields: [operatorId], references: [id])

  @@index([userId])
  @@index([referenceType, referenceId])
  @@map("wallet_transactions")
}

model RechargeRequest {
  id             String       @id @default(cuid())
  customerId     String
  amount         Decimal      @db.Decimal(12, 2)
  screenshotUrl  String
  note           String?
  status         ReviewStatus @default(PENDING)
  reviewedById   String?
  reviewedAt     DateTime?
  reviewNote     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  customer       User         @relation("RechargeCustomer", fields: [customerId], references: [id])
  reviewedBy     User?        @relation("RechargeReviewer", fields: [reviewedById], references: [id])

  @@index([status])
  @@map("recharge_requests")
}

model WithdrawalRequest {
  id              String           @id @default(cuid())
  companionId     String
  amount          Decimal          @db.Decimal(12, 2)
  payoutAccount   String
  note            String?
  status          WithdrawalStatus @default(PENDING)
  reviewedById    String?
  reviewedAt      DateTime?
  reviewNote      String?
  paidAt          DateTime?
  payoutReference String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  companion       User             @relation("WithdrawalCompanion", fields: [companionId], references: [id])
  reviewedBy      User?            @relation("WithdrawalReviewer", fields: [reviewedById], references: [id])

  @@index([status])
  @@map("withdrawal_requests")
}

model Complaint {
  id           String          @id @default(cuid())
  orderId      String
  reporterId   String
  resolvedById String?
  reason       String
  status       ComplaintStatus @default(OPEN)
  resolution   String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  order        Order           @relation(fields: [orderId], references: [id])
  reporter     User            @relation("ComplaintReporter", fields: [reporterId], references: [id])
  resolvedBy   User?           @relation("ComplaintResolver", fields: [resolvedById], references: [id])

  @@index([status])
  @@map("complaints")
}

model AdminLog {
  id           String   @id @default(cuid())
  actorId      String
  targetUserId String?
  action       String
  entityType   String
  entityId     String?
  detail       Json?
  ipAddress    String?
  createdAt    DateTime @default(now())

  actor        User     @relation("AdminLogActor", fields: [actorId], references: [id])
  targetUser   User?    @relation("AdminLogTarget", fields: [targetUserId], references: [id])

  @@index([actorId])
  @@index([entityType, entityId])
  @@map("admin_logs")
}

model PlatformSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  updatedBy   User?    @relation("PlatformSettingUpdater", fields: [updatedById], references: [id])

  @@map("platform_settings")
}

model AiSupportConversation {
  id              String   @id @default(cuid())
  userId          String?
  platform        BotPlatform?
  platformUserId  String?
  platformGuildId String?
  platformChannelId String?
  platformMessageId String?
  replyMessageId  String?
  message         String
  answer          String
  matchedTopic    String?
  handoffRequired Boolean  @default(false)
  createdAt       DateTime @default(now())

  user            User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([platform, platformUserId])
  @@index([platformChannelId])
  @@index([createdAt])
  @@map("ai_support_conversations")
}

model BotEvent {
  id              String       @id @default(cuid())
  platform        BotPlatform
  status          BotEventStatus @default(PENDING)
  type            BotEventType
  actorId         String?
  orderId         String?
  discordGuildId  String?
  discordChannelId String?
  discordMessageId String?
  platformGuildId String?
  platformChannelId String?
  platformMessageId String?
  platformUserId  String?
  payload         Json?
  error          String?
  retryCount     Int          @default(0)
  createdAt       DateTime     @default(now())

  actor           User?        @relation("BotEventActor", fields: [actorId], references: [id])

  @@index([type])
  @@index([orderId])
  @@map("bot_events")
}
